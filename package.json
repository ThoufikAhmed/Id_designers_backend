{
  "name": "fabtrakr-server",
  "version": "1.0.0",
  "description": "Fabric Tracker",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "npx nodemon ./src/index.js",
    "docker": "./scripts/run-docker-container.sh",
    "standard": "./node_modules/.bin/standard --fix",
    "test": "NODE_ENV=test nyc ./node_modules/.bin/mocha --timeout 45000 --exit",
    "unit-test": "set NODE_ENV=unit-tests && mocha ./src/**/*.test.js",
    "document": "./node_modules/.bin/jsdoc -r ./src ./test -c ./jsdoc.conf.json",
    "seed": "node ./seed/index.js",
    "revert-seed": "node ./seed/revert.js"
  },
  "author": "Indian Designs",
  "license": "ISC",
  "dependencies": {
    "@hapi/joi": "^15.1.1",
    "aws-sdk": "^2.1059.0",
    "axios": "^0.20.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^8.2.0",
    "exceljs": "^4.4.0",
    "express": "^4.17.1",
    "express-api-cache": "^1.0.4",
    "express-jwt": "^6.0.0",
    "helmet": "^4.1.0",
    "is-reachable": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^1.9.0",
    "morgan": "^1.10.0",
    "mssql": "^5.1.2",
    "mysql": "^2.18.1",
    "mysql2": "^3.11.3",
    "nanoid": "^2.1.11",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.4.11",
    "pm2": "^5.4.3",
    "uuid": "^8.3.2",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-http": "^4.3.0",
    "faker": "^5.5.1",
    "husky": "^4.2.5",
    "jsdoc": "^3.6.6",
    "minimist": "^1.2.5",
    "mocha": "^8.3.2",
    "nyc": "^15.1.0",
    "proxyquire": "^2.1.3",
    "sinon": "^9.0.3",
    "standard": "^14.3.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run standard && npm run unit-test"
    }
  },
  "standard": {
    "env": [
      "mocha"
    ]
  }
}
